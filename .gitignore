# dependencies
node_modules/
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local env files
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE
.vscode/
.idea/

# OS
desktop.ini

# Generated files (uploaded by users in app workflows)
/tmp/
/uploads/

# Playwright/test artifacts
/.playwright-mcp/
/test-results/
phase-*.png
page-*.png

# All app-level test output stays inside the app folder, never at the root.
apps/*/test-output/

# Local-only scraped content for the AI Learning Community app — never commit
apps/AI Learning Community/scraped/

# Local-only candidate materials for the endowed-positions app — never commit
# CVs, dept head letters, or anything else PII-bearing. Only the Boivie
# example (institutional template) and the candidate metadata in
# src/lib/endowed-positions are tracked.
apps/Endowed Positions Letter Writer/Source Materials/

# Claude scheduler internals
/.claude/scheduled_tasks.lock

# Form submissions saved by /your-ai-edge intake forms — never commit
data/submissions/

# Local-only scraped source data for the Apps chatbots — regenerate via scripts.
# The Academic Calendar Chatbot reads data/sources/academic-calendar.json at
# request time. The file is regenerated by scripts/_scrape-academic-calendar.mjs
# and is not tracked because it is bulky and refresh-able. Use data/sources/*
# (not data/sources/) so per-file exceptions below can re-include specific
# files.
data/sources/*

# Exception: the Mays Faculty Guidelines source text and the canonical PDF
# are checked in because they live only in Hari's OneDrive and Render cannot
# reach that path at build time. Refresh by running
# scripts/_extract-faculty-guidelines.mjs locally and committing the new
# .txt and .pdf.
!data/sources/mays-faculty-guidelines.txt
!data/sources/mays-faculty-guidelines.pdf

# Audit logs from the Apps chatbots (one JSONL per day per bucket). Local-only,
# never tracked. Used for spot-review by Hari, not shipped.
data/audit/

# PowerPoint Reformatter — user uploads and generated outputs are local-only.
# The template at apps/PowerPoint Reformatter/template/mays-template.pptx is
# tracked; everything users upload or the app produces is not.
apps/PowerPoint Reformatter/uploads/
data/pptx-uploads/
data/pptx-outputs/
