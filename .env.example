ANTHROPIC_API_KEY=sk-ant-...
ADMIN_PASSWORD=change-me

# Optional — secret used to sign session cookies. If unset, ADMIN_PASSWORD is used.
SESSION_SECRET=

# Google OAuth (primary auth, restricted server-side to @tamu.edu).
# See docs/AUTH-SETUP.md for how to register the OAuth client.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Future — TAMU CAS SSO integration (target replacement for the Google OAuth bridge):
# TAMU_CAS_SERVICE_URL=
# TAMU_CAS_VALIDATE_URL=
